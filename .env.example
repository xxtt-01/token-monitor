# Token Monitor — environment configuration.
# Copy to .env (gitignored) and fill in. Only needed for the hub and the
# headless agent; the widget can also read these as first-run defaults
# before its GUI settings take over.

# Hub URL — required for the agent and for any widget in sync mode.
# Leave empty for single-device local mode (widget reads files directly, no hub).
# Example: https://token-monitor-hub.<your-subdomain>.workers.dev  or  http://192.168.1.10:17321
TOKEN_MONITOR_HUB_URL=

# Shared secret — must match on the hub, agent, and any widget that syncs.
# Leave empty to run the hub without authentication (not recommended).
# Generate a random one with: openssl rand -hex 32
TOKEN_MONITOR_SECRET=

# Device identifier. Optional — defaults to the machine hostname.
TOKEN_MONITOR_DEVICE_ID=

# Comma-separated client list. Optional — leave unset to track all supported tools.
# Set to empty to disable tracking.
# Example: claude,codex,hermes,opencode,openclaw,cursor,antigravity,cline,kimi,qwen,grok
TOKEN_MONITOR_CLIENTS=claude,codex,hermes,opencode,openclaw,cursor,antigravity,cline,kimi,qwen,grok

# Usage Trends — collect historical trend data for the Trends dashboard.
# Optional — defaults to disabled. Set to 1 to enable.
TOKEN_MONITOR_HISTORY_ENABLED=0

# AI Tool Limits — detect supported provider session, weekly, billing, and credit windows.
# Optional — defaults to enabled. Set to 0 to disable entirely (skips probing the local CLIs).
TOKEN_MONITOR_LIMITS_ENABLED=

# Providers to probe. Optional — defaults to all supported (claude, codex, cursor, antigravity, opencode, deepseek).
# Example: claude,codex   (probe only Claude Code and Codex)
TOKEN_MONITOR_LIMIT_PROVIDERS=

# DeepSeek balance API key. Optional — the widget has a GUI account setting;
# use this for the headless agent, hubless scripts, or environment-managed secrets.
DEEPSEEK_API_KEY=
