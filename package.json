{
  "name": "token-monitor",
  "productName": "Token Monitor",
  "version": "0.1.0",
  "description": "Live token & cost widget for Claude Code, Codex & Hermes — local-first, optional multi-device sync.",
  "main": "src/electron/main.js",
  "scripts": {
    "start": "electron .",
    "hub": "node src/hub/server.js",
    "agent": "node src/agent/agent.js",
    "agent:once": "node src/agent/agent.js --once",
    "widget": "electron .",
    "dev": "electron .",
    "icons": "node -e \"require('node:fs').mkdirSync('build', { recursive: true })\" && electron-icon-builder --input=assets/icon.png --output=build --flatten",
    "prepack": "npm run icons",
    "predist:mac": "npm run icons",
    "predist:win": "npm run icons",
    "pack": "electron-builder --dir",
    "dist:mac": "electron-builder --mac --arm64",
    "dist:win": "electron-builder --win --x64",
    "check": "node --check src/hub/server.js && node --check src/agent/agent.js && node --check src/shared/collector.js && node --check src/shared/config.js && node --check src/shared/http.js && node --check src/shared/limitCollector.js && node --check src/shared/limits.js && node --check src/shared/tokscalePlatform.js && node --check src/shared/tokscaleUpdater.js && node --check src/shared/usage.js && node --check src/electron/main.js && node --check src/electron/preload.js && node --check src/electron/discordRpc.js && node --check src/electron/tray.js && node --check src/electron/renderer/app.js && node --check worker/src/index.js && node --check tests/shared/config.test.js && node --check tests/shared/platformPackage.test.js && node --check tests/shared/collectorResolver.test.js && node --check tests/shared/tokscaleUpdater.test.js"
  },
  "build": {
    "appId": "com.javis.tokenmonitor",
    "productName": "Token Monitor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/electron/**/*",
      "src/shared/**/*",
      "assets/icon.png",
      "assets/icons/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@tokscale/**/*",
      "node_modules/tokscale/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icons/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico"
    },
    "publish": null
  },
  "keywords": [
    "tokscale",
    "claude-code",
    "codex",
    "hermes",
    "token-monitor",
    "token-usage",
    "cost-tracking",
    "llm",
    "ai-tools",
    "electron",
    "desktop-widget",
    "local-first",
    "self-hosted"
  ],
  "author": "Javis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Javis603/token-monitor.git"
  },
  "homepage": "https://github.com/Javis603/token-monitor#readme",
  "bugs": {
    "url": "https://github.com/Javis603/token-monitor/issues"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "chokidar": "^3.6.0",
    "dotenv": "^17.4.2",
    "semver": "^7.8.1",
    "tar": "^7.5.15",
    "tokscale": "^2.1.3"
  },
  "devDependencies": {
    "electron": "42.2.0",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1"
  },
  "engines": {
    "node": ">=18.17"
  }
}
